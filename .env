# ──────────────────────────────────────────────────
# .env — Environment variable overrides (optional)
# Copy this file and rename it to .env to customise.
# Never commit real secrets to version control.
# ──────────────────────────────────────────────────

# Camera device index (0 = default webcam, 1 for external)
CAMERA_INDEX=0

# GPU index for TensorFlow (set to -1 for CPU-only)
CUDA_VISIBLE_DEVICES=0
